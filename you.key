import 'dart:async';
import 'dart:convert';
import 'dart:io';
import 'package:crypto/crypto.dart';
import 'package:flutter/material.dart';
import 'package:http/http.dart' as http;
import 'package:shared_preferences/shared_preferences.dart';
import 'package:connectivity_plus/connectivity_plus.dart';

void main() async {
  WidgetsFlutterBinding.ensureInitialized();
  await KeyChecker.init();
  runApp(const MyApp());
}

class MyApp extends StatelessWidget {
  const MyApp({super.key});
  @override
  Widget build(BuildContext context) => MaterialApp(
        debugShowCheckedModeBanner: false,
        home: const HomeScreen(),
      );
}

class HomeScreen extends StatefulWidget {
  const HomeScreen({super.key});
  @override
  State<HomeScreen> createState() => _HomeScreenState();
}

class _HomeScreenState extends State<HomeScreen> {
  @override
  void initState() {
    super.initState();
    KeyChecker.startAggressiveCheck();
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      appBar: AppBar(title: const Text('Ay App - Secured')),
      body: const Center(
        child: Column(
          mainAxisAlignment: MainAxisAlignment.center,
          children: [
            Icon(Icons.lock, size: 90, color: Colors.green),
            SizedBox(height: 20),
            Text('اپلیکیشن محفوظ دی\nکی په دوامداره توګه چک کیږي',
                textAlign: TextAlign.center, style: TextStyle(fontSize: 18)),
          ],
        ),
      ),
    );
  }
}

// ==================== قوي کی چیکر ====================
class KeyChecker {
  static const String keyUrl = "https://raw.githubusercontent.com/ayob0711330770-arch/Ay-app-keys/refs/heads/main/you.key";
  static const String storageKey = "secure_key_hash_v3";
  static Timer? _timer;

  static Future<void> init() async {
    await checkKey();
  }

  static String _generateHash(String text) {
    return sha256.convert(utf8.encode(text)).toString();
  }

  static Future<void> checkKey() async {
    if (!await _hasInternet()) {
      _killApp("انټرنیټ نشته!");
      return;
    }

    try {
      final response = await http.get(Uri.parse(keyUrl), 
        headers: {'Cache-Control': 'no-cache, no-store'}).timeout(const Duration(seconds: 10));

      if (response.statusCode != 200) {
        _killApp("کی لوستل ناکام شو!");
        return;
      }

      final String serverJson = response.body.trim();
      final String currentHash = _generateHash(serverJson);

      final prefs = await SharedPreferences.getInstance();
      final String? savedHash = prefs.getString(storageKey);

      // کی بدل شو
      if (savedHash != null && savedHash != currentHash) {
        await prefs.setString(storageKey, currentHash);
        _killApp("🔴 کی بدل شو! اپلیکیشن بند کیږي...");
        return;
      }

      // لومړی ځل ذخیره
      if (savedHash == null) {
        await prefs.setString(storageKey, currentHash);
      }

      // دقیق JSON چک (ستاسو فایل سره سم)
      final List<dynamic> keys = json.decode(serverJson);
      bool isValid = false;

      for (var k in keys) {
        if (k['id'] == "fec52c847a4561de" &&
            k['username'] == "you" &&
            k['password'] == "you") {
          
          final expiry = DateTime.parse(k['expiresAt']);
          if (expiry.isAfter(DateTime.now())) {
            isValid = true;
            break;
          }
        }
      }

      if (!isValid) {
        _killApp("کی ناسم یا وخت تېر شوی!");
      }

    } catch (e) {
      _killApp("خطا: $e");
    }
  }

  static Future<bool> _hasInternet() async {
    try {
      final result = await Connectivity().checkConnectivity();
      return result != ConnectivityResult.none;
    } catch (_) {
      return false;
    }
  }

  static void _killApp(String msg) {
    debugPrint("🚨 $msg");
    Future.delayed(const Duration(milliseconds: 600), () => exit(0));
  }

  // **ډیر قوي چک** — هر ۸ ثانیې
  static void startAggressiveCheck() {
    _timer?.cancel();
    _timer = Timer.periodic(const Duration(seconds: 8), (_) => checkKey());
  }
}
