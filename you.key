<!DOCTYPE html>
<html lang="ps">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>د کیلي او وسیلې د تایید سیسټم</title>
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #0f172a;
            color: #ffffff;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
            direction: rtl;
        }
        .auth-card {
            background: #1e293b;
            padding: 30px;
            border-radius: 12px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.3);
            text-align: center;
            width: 350px;
            border: 1px solid #334155;
        }
        h2 { color: #38bdf8; margin-bottom: 20px; }
        input {
            width: 100%;
            padding: 12px;
            margin: 10px 0;
            border: 1px solid #475569;
            border-radius: 6px;
            background: #0f172a;
            color: white;
            box-sizing: border-box;
            text-align: center;
        }
        button {
            background-color: #38bdf8;
            color: #0f172a;
            border: none;
            padding: 12px;
            border-radius: 6px;
            cursor: pointer;
            font-size: 16px;
            font-weight: bold;
            width: 100%;
            margin-top: 10px;
        }
        button:hover { background-color: #0ea5e9; }
        .result-box {
            margin-top: 20px;
            padding: 15px;
            border-radius: 6px;
            display: none;
            text-align: right;
            font-size: 14px;
            line-height: 1.6;
        }
        .success { background: #16a34a; color: white; }
        .error { background: #dc2626; color: white; }
    </style>
</head>
<body>

<div class="auth-card">
    <h2>د نښلولو او کیلي سیسټم</h2>
    
    <input type="password" id="adminPassword" placeholder="د ننوتلو اصلي رمز ولیکئ...">
    <input type="text" id="deviceIdInput" placeholder="د وسیلې آئي ډي (Device ID)...">
    <input type="text" id="keyInput" placeholder="د تایید کیلي (Key)...">
    
    <button onclick="validateLicense()">تاییدول</button>
    
    <div id="result" class="result-box"></div>
</div>

<script>
    // ستاسو لخوا مشخص شوی ډاټا
    const allowedData = [
        { "device_id": "fec52c847a4561de", "key": "you", "expirydate": "30-12-2026", "Allowoffline": true },
        { "device_id": "fec52c847a4561de", "key": "you", "expirydate": "30-12-2026", "Allowoffline": false },
        { "device_id": "fec52c847a4561de", "key": "you", "expirydate": "30-12-2026", "Allowoffline": false }
    ];

    function validateLicense() {
        const password = document.getElementById('adminPassword').value;
        const deviceId = document.getElementById('deviceIdInput').value.trim();
        const userKey = document.getElementById('keyInput').value.trim();
        const resultBox = document.getElementById('result');

        // ۱. لومړی د اصلي پاڼې رمز چک کوي
        if (password !== "you123") {
            resultBox.className = "result-box error";
            resultBox.style.display = "block";
            resultBox.innerHTML = "❌ د ننوتلو رمز (you123) غلط دی!";
            return;
        }

        // ۲. بیا په لیسټ کې د Device ID او Key مطابقت ګوري
        const match = allowedData.find(item => item.device_id === deviceId && item.key === userKey);

        if (match) {
            resultBox.className = "result-box success";
            resultBox.style.display = "block";
            resultBox.innerHTML = `
                ✅ **تایید شو!**<br>
                📅 **د پای نېټه:** ${match.expirydate}<br>
                🌐 **آفلین اجازه:** ${match.Allowoffline ? "هو (True)" : "نه (False)"}
            `;
        } else {
            resultBox.className = "result-box error";
            resultBox.style.display = "block";
            resultBox.innerHTML = "❌ ورکړل شوې کیلي یا ډیوائس آئي ډي په سیسټم کې شتون نلري!";
        }
    }
</script>

</body>
</html>
